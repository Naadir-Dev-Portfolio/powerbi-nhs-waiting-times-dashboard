	partition 'Fact National RTT Monthly' = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_national_rtt_monthly.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers", {{"Date", type date}, {"Total Waiting List", Int64.Type}, {"Within 18 Weeks", Int64.Type}, {"Over 18 Weeks", Int64.Type}, {"Over 52 Weeks", Int64.Type}, {"Within 18 Weeks Rate", type number}, {"Over 18 Weeks Rate", type number}, {"Over 52 Weeks Rate", type number}, {"Median Wait Weeks", type number}, {"92nd Percentile Wait Weeks", type number}, {"Within 18 Weeks Target", type number}, {"Source", type text}}, "en-GB")
